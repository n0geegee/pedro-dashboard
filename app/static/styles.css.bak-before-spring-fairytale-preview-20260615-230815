/* Pedro Dashboard — HERMES three-zone media dashboard
 * Target: 1920x1200 native, no scroll, dark glass cockpit.
 * Stack: Python stdlib + static HTML/CSS/vanilla JS. No remote images.
 */

:root {
  --bg-0: #070a10;
  --bg-1: #0c1118;
  --bg-2: #11171f;
  --bg-3: #161d27;
  --bg-4: #1b2330;
  --line: #232c3a;
  --line-2: #2c3645;
  --fg: #e6edf6;
  --fg-soft: #c1cad6;
  --fg-mute: #8a96a8;
  --fg-dim: #5d6878;
  --accent: #4ea1ff;
  --accent-soft: rgba(78, 161, 255, 0.16);
  --red: #ff3b3b;
  --red-2: #e02424;
  --green: #2bd66a;
  --green-soft: rgba(43, 214, 106, 0.18);
  --orange: #f59f3a;
  --yellow: #facc15;
  --blue: #3b82f6;
  --blue-soft: rgba(59, 130, 246, 0.18);
  --poland: #dc1d24;

  --shadow-1: 0 1px 0 rgba(255, 255, 255, 0.02), 0 6px 16px rgba(0, 0, 0, 0.35);
  --radius-card: 14px;
  --radius-inner: 10px;
  --gap: 14px;
  --ticker-h: 54px;
  --skin-overlay-url: none;
  --skin-overlay-opacity: 0;
  --skin-overlay-blend: soft-light;
  --body-bg:
    radial-gradient(1200px 800px at 12% -8%, #0e1a2a 0%, transparent 60%),
    radial-gradient(1100px 700px at 100% 100%, #0a1822 0%, transparent 55%),
    radial-gradient(900px 600px at 50% 50%, #0a121d 0%, transparent 60%),
    linear-gradient(180deg, #06090f 0%, #04070c 100%);
}

body[data-skin="winter"] {
  --bg-0: #061019; --bg-1: #0a1824; --bg-2: #102131; --bg-3: #162a3b; --bg-4: #1d3448;
  --line: #294054; --line-2: #38566d;
  --fg: #eef8ff; --fg-soft: #cfe4f2; --fg-mute: #92aebe; --fg-dim: #637d8b;
  --accent: #9bd8ff; --accent-soft: rgba(155,216,255,0.18);
  --body-bg:
    radial-gradient(1000px 650px at 8% -8%, rgba(170,220,255,0.22), transparent 58%),
    radial-gradient(900px 620px at 96% 100%, rgba(70,120,165,0.18), transparent 58%),
    linear-gradient(180deg, #061019 0%, #03070d 100%);
}
body[data-skin="spring"] {
  --bg-0: #07110d; --bg-1: #0d1a13; --bg-2: #14231a; --bg-3: #1a2e21; --bg-4: #203929;
  --line: #2d4635; --line-2: #3d6048;
  --fg: #ecfff4; --fg-soft: #c9ead5; --fg-mute: #93b99f; --fg-dim: #668471;
  --accent: #7ee38f; --accent-soft: rgba(126,227,143,0.18);
  --skin-overlay-url: url("/static/skins/spring-fairytale-overlay.svg");
  --skin-overlay-opacity: 0.62;
  --skin-overlay-blend: screen;
  --body-bg:
    radial-gradient(950px 620px at 10% -8%, rgba(126,227,143,0.20), transparent 58%),
    radial-gradient(880px 580px at 100% 100%, rgba(255,170,210,0.13), transparent 60%),
    linear-gradient(180deg, #07110d 0%, #030806 100%);
}
body[data-skin="summer"] {
  --bg-0: #061018; --bg-1: #081926; --bg-2: #102633; --bg-3: #173544; --bg-4: #1d4253;
  --line: #264c5d; --line-2: #34687a;
  --fg: #f1fbff; --fg-soft: #cdeaf4; --fg-mute: #91b7c6; --fg-dim: #638493;
  --accent: #55d6ff; --accent-soft: rgba(85,214,255,0.18);
  --body-bg:
    radial-gradient(1100px 700px at 8% -10%, rgba(85,214,255,0.22), transparent 58%),
    radial-gradient(950px 620px at 100% 100%, rgba(250,204,21,0.12), transparent 58%),
    linear-gradient(180deg, #061018 0%, #02070b 100%);
}
body[data-skin="autumn"] {
  --bg-0: #120b07; --bg-1: #1b110b; --bg-2: #26180f; --bg-3: #342115; --bg-4: #422a19;
  --line: #553620; --line-2: #70482a;
  --fg: #fff4ea; --fg-soft: #ead1bd; --fg-mute: #b99272; --fg-dim: #84664d;
  --accent: #f59f3a; --accent-soft: rgba(245,159,58,0.18);
  --body-bg:
    radial-gradient(1000px 650px at 10% -10%, rgba(245,159,58,0.20), transparent 60%),
    radial-gradient(900px 620px at 100% 100%, rgba(220,80,30,0.13), transparent 60%),
    linear-gradient(180deg, #120b07 0%, #070403 100%);
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  height: 100%;
  overflow: hidden;
  color: var(--fg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", "SF Pro Display", system-ui, sans-serif;
  font-size: 14px;
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

body {
  display: grid;
  grid-template-rows: 1fr var(--ticker-h);
  height: 100vh;
  background: var(--body-bg);
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background-image: var(--skin-overlay-url);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  opacity: var(--skin-overlay-opacity);
  mix-blend-mode: var(--skin-overlay-blend);
}

body > * { position: relative; z-index: 1; }

/* ========== BOTTOM PASSIVE TICKER ========== */

.info-ticker {
  height: var(--ticker-h);
  display: grid;
  grid-template-columns: 205px minmax(0, 1fr);
  align-items: center;
  gap: 18px;
  padding: 0 24px;
  background: linear-gradient(180deg, rgba(4, 7, 12, 0.35), rgba(8, 12, 20, 0.92));
  border-top: 1px solid var(--line);
  box-shadow: 0 -10px 28px rgba(0, 0, 0, 0.28);
  overflow: hidden;
}
.ticker-clock {
  font-variant-numeric: tabular-nums;
  font-size: 23px;
  font-weight: 800;
  letter-spacing: 0.4px;
  color: #f3f7ff;
  text-align: left;
}
.ticker-window {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  mask-image: linear-gradient(90deg, transparent 0%, #000 5%, #000 95%, transparent 100%);
}
.ticker-track {
  display: inline-flex;
  align-items: center;
  gap: 34px;
  white-space: nowrap;
  color: var(--fg-soft);
  font-size: 15px;
  font-weight: 650;
  letter-spacing: 0.15px;
  animation: ticker-scroll 48s linear infinite;
  will-change: transform;
}
.ticker-track span { display: inline-flex; align-items: center; gap: 10px; }
.ticker-track span::before {
  content: "";
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 8px rgba(255, 59, 59, 0.7);
}
@keyframes ticker-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ========== LAYOUT ========== */

.layout {
  display: grid;
  grid-template-columns: 432px 1fr 736px;
  gap: var(--gap);
  padding: 16px 16px 12px;
  min-height: 0;
  height: 100%;
}

.col {
  display: grid;
  gap: var(--gap);
  min-height: 0;
  min-width: 0;
}

.col--left  { grid-template-rows: 1.55fr 0.85fr 1.05fr 1.15fr; }
.col--center { grid-template-rows: 1.05fr 0.95fr; }
.col--right  { grid-template-rows: 1.05fr 0.95fr; }

/* ========== CARDS ========== */

.card {
  display: flex;
  flex-direction: column;
  background:
    linear-gradient(180deg, rgba(28, 36, 50, 0.55) 0%, rgba(18, 24, 34, 0.55) 100%);
  border: 1px solid var(--line);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-1);
  overflow: hidden;
  min-height: 0;
  min-width: 0;
  position: relative;
}

.card__head {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 18px;
  border-bottom: 1px solid var(--line);
  background: linear-gradient(180deg, rgba(22, 28, 40, 0.55), rgba(16, 22, 32, 0.4));
  flex: 0 0 auto;
}
.card__num,
.card__pos {
  color: var(--fg-mute);
  font-weight: 600;
  font-size: 12px;
  letter-spacing: 0.4px;
}
.card__title {
  margin: 0;
  font-size: 12.5px;
  font-weight: 700;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  color: var(--fg-soft);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card__body {
  padding: 12px 16px 14px;
  flex: 1 1 auto;
  min-height: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.muted { color: var(--fg-mute); }
.dim   { color: var(--fg-dim);  font-size: 12px; }

/* ========== WEATHER ========== */

.weather { display: flex; flex-direction: column; gap: 10px; min-height: 0; }
.weather__city { font-size: 13px; color: var(--fg-soft); font-weight: 500; }
.weather__row  {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 8px;
}
.weather__temp {
  font-size: 56px;
  font-weight: 300;
  line-height: 1;
  letter-spacing: -1px;
  color: #f3f6fb;
  font-variant-numeric: tabular-nums;
}
.weather__icon { width: 72px; height: 72px; display: block; }
.weather__cond { font-size: 15px; font-weight: 600; color: var(--fg); }
.weather__feels { color: var(--fg-mute); font-size: 12px; margin-top: 2px; }

.weather__metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px 12px;
  padding: 8px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.weather__metric { display: flex; flex-direction: column; }
.weather__metric-label { color: var(--fg-mute); font-size: 11px; }
.weather__metric-value { color: var(--fg); font-size: 13px; font-weight: 600; }

.weather__hours {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
  text-align: center;
  font-size: 12px;
}
.weather__hour { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.weather__hour-t  { color: var(--fg-mute); font-size: 11px; }
.weather__hour-i  { font-size: 18px; line-height: 1; }
.weather__hour-d  { color: var(--fg); font-weight: 600; }

/* ========== ROUTE ========== */

.route { display: flex; flex-direction: column; gap: 6px; min-height: 0; }
.route__time {
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
}
.route__time-window { font-size: 17px; font-weight: 600; color: var(--fg); }
.route__time-dur    { color: var(--green); font-weight: 700; font-size: 14px; }
.route__note        { color: var(--fg-mute); font-size: 12px; }

.route__map {
  position: relative;
  flex: 1 1 auto;
  min-height: 60px;
  border-radius: var(--radius-inner);
  overflow: hidden;
  background:
    radial-gradient(120% 120% at 30% 30%, rgba(46, 76, 112, 0.55), rgba(14, 22, 34, 0.95)),
    repeating-linear-gradient(0deg,  rgba(255,255,255,0.04) 0 1px, transparent 1px 28px),
    repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0 1px, transparent 1px 28px),
    linear-gradient(135deg, #0b1422, #142035 60%, #0b1422);
  border: 1px solid var(--line);
}
.route__map::before {
  /* faint roads */
  content: "";
  position: absolute; inset: 0;
  background:
    linear-gradient(70deg, transparent 38%, rgba(180,210,255,0.07) 39%, transparent 41%),
    linear-gradient(110deg, transparent 60%, rgba(180,210,255,0.05) 61%, transparent 63%),
    linear-gradient(150deg, transparent 70%, rgba(180,210,255,0.06) 71%, transparent 73%);
  pointer-events: none;
}
.route__map svg { position: absolute; inset: 0; width: 100%; height: 100%; }
.route__map-pin { fill: #4ea1ff; }
.route__map-home { fill: #2bd66a; }
.route__map-label {
  position: absolute;
  color: var(--fg-soft);
  font-size: 11px;
  font-weight: 600;
  text-shadow: 0 1px 2px rgba(0,0,0,0.8);
}
.route__map-label.start { left: 14px; top: 12px; }
.route__map-label.end   { right: 14px; bottom: 10px; }
.route__map-label.city  { left: 50%; top: 8px; transform: translateX(-50%); color: var(--fg-mute); font-weight: 500; }

/* ========== CALENDAR ========== */

.calendar { display: flex; flex-direction: column; gap: 8px; min-height: 0; }
.calendar__date { color: var(--fg-soft); font-size: 13px; font-weight: 500; }
.calendar__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 5px; min-height: 0; overflow: hidden; }
.calendar__item {
  display: grid;
  grid-template-columns: 50px 1fr;
  align-items: center;
  gap: 8px;
  padding: 2px 0;
  font-size: 13px;
}
.calendar__time { color: var(--fg-mute); font-variant-numeric: tabular-nums; font-size: 12px; }
.calendar__title { color: var(--fg); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.calendar__dot {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  margin-right: 6px;
  vertical-align: middle;
}

/* ========== ALERTS ========== */

.alerts { display: flex; flex-direction: column; gap: 8px; min-height: 0; }
.alerts__list { display: flex; flex-direction: column; gap: 8px; min-height: 0; overflow: auto; }
.alert-card {
  display: grid;
  grid-template-columns: 28px 1fr auto;
  gap: 10px;
  align-items: start;
  padding: 8px 10px;
  background: rgba(20, 26, 36, 0.6);
  border: 1px solid var(--line);
  border-radius: 8px;
}
.alert-card__icon {
  width: 26px; height: 26px;
  border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 13px;
  color: #fff;
}
.alert-card__icon--green  { background: var(--green); }
.alert-card__icon--blue   { background: var(--blue); }
.alert-card__icon--orange { background: var(--orange); }
.alert-card__icon--red    { background: var(--red); }
.alert-card__head { display: flex; align-items: center; gap: 8px; }
.alert-card__kind { font-size: 11.5px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
.alert-card__kind--green  { color: var(--green); }
.alert-card__kind--blue   { color: #82b4ff; }
.alert-card__title { color: var(--fg); font-size: 13px; font-weight: 500; }
.alert-card__sub  { color: var(--fg-mute); font-size: 12px; }
.alert-card__time { color: var(--fg-dim); font-size: 11px; align-self: center; }
.alerts__more {
  display: flex; align-items: center; justify-content: space-between;
  color: var(--fg-mute); font-size: 12px;
  padding: 4px 2px 0;
  border-top: 1px dashed var(--line);
  margin-top: 4px;
}
.alerts__more .chev { color: var(--fg-dim); }

/* ========== VOLLEYBALL ========== */

.vb { display: flex; flex-direction: column; gap: 6px; min-height: 0; }
.vb__tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--line);
  margin-bottom: 4px;
}
.vb__tab {
  display: inline-flex;
  background: transparent;
  border: 0;
  padding: 10px 16px 12px;
  color: var(--fg-mute);
  font-size: 15px;
  font-weight: 800;
  letter-spacing: 0.55px;
  text-transform: uppercase;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
}
.vb__tab--active { color: var(--fg); border-bottom-color: var(--red); }

.vb__list { display: flex; flex-direction: column; gap: 10px; min-height: 0; overflow: hidden; }
.vb__row {
  display: grid;
  grid-template-columns: 142px 1fr 150px;
  align-items: center;
  gap: 16px;
  padding: 12px 16px;
  background: rgba(18, 24, 34, 0.72);
  border: 1px solid var(--line-2);
  border-radius: 10px;
  font-size: 16px;
  min-height: 58px;
}
.vb__when { color: var(--fg-mute); font-size: 14px; line-height: 1.2; font-weight: 750; }
.vb__when strong { color: var(--fg); display: block; font-weight: 850; font-size: 15px; margin-bottom: 2px; }

.vb__match { display: flex; align-items: center; justify-content: center; gap: 14px; }
.vb__team { display: flex; align-items: center; gap: 10px; min-width: 0; }
.vb__team-name { color: var(--fg); font-weight: 800; font-size: 18px; line-height: 1.05; }
.vb__vs   { color: var(--fg-dim); font-size: 13px; font-weight: 850; letter-spacing: 0.5px; }
.flag {
  display: inline-block;
  width: 28px; height: 18px;
  border-radius: 3px;
  background-size: cover;
  background-position: center;
  border: 1px solid rgba(255,255,255,0.12);
  box-shadow: 0 1px 1px rgba(0,0,0,0.4);
  flex: 0 0 28px;
}
.flag--pl { background: linear-gradient(180deg, #fff 50%, var(--poland) 50%); }
.flag--br { background: linear-gradient(180deg, var(--green) 0%, var(--yellow) 100%); }
.flag--jp { background: #fff; position: relative; }
.flag--jp::after { content: ""; position: absolute; left: 50%; top: 50%; width: 8px; height: 8px; transform: translate(-50%,-50%); background: #bc002d; border-radius: 50%; }
.flag--it { background: linear-gradient(90deg, #009246 0%, #009246 33%, #fff 33%, #fff 66%, #ce2b37 66%); }
.flag--ar { background: linear-gradient(180deg, #74acdf 0%, #74acdf 33%, #fff 33%, #fff 66%, #74acdf 66%); }
.flag--rs { background: linear-gradient(180deg, #c6363c 0%, #c6363c 33%, #0c4076 33%, #0c4076 66%, #fff 66%); }
.flag--tr { background: #e30a17; }
.flag--us { background: repeating-linear-gradient(180deg, #b22234 0 4px, #fff 4px 8px); }
.flag--cn { background: #de2910; }
.flag--fr { background: linear-gradient(90deg, #002395 0%, #002395 33%, #fff 33%, #fff 66%, #ed2939 66%); }
.flag--de { background: linear-gradient(180deg, #000 0%, #000 33%, #dd0000 33%, #dd0000 66%, #ffce00 66%); }
.flag--be { background: linear-gradient(90deg, #000 0%, #000 33%, #fae042 33%, #fae042 66%, #ed2939 66%); }
.flag--bg { background: linear-gradient(180deg, #fff 0%, #fff 33%, #00966e 33%, #00966e 66%, #d62612 66%); }
.flag--ua { background: linear-gradient(180deg, #0057b7 0%, #0057b7 50%, #ffd700 50%); }
.flag--nl { background: linear-gradient(180deg, #ae1c28 0%, #ae1c28 33%, #fff 33%, #fff 66%, #21468b 66%); }
.flag--ca { background: linear-gradient(90deg, #d52b1e 0%, #d52b1e 25%, #fff 25%, #fff 75%, #d52b1e 75%); }
.flag--cz { background: linear-gradient(180deg, #fff 0%, #fff 50%, #d7141a 50%); position: relative; }
.flag--cz::before { content: ""; position: absolute; left: 0; top: 0; border-top: 8px solid transparent; border-bottom: 8px solid transparent; border-left: 13px solid #11457e; }
.flag--si { background: linear-gradient(180deg, #fff 0%, #fff 33%, #005da4 33%, #005da4 66%, #ed1c24 66%); }

.vb__meta {
  text-align: right;
  color: var(--fg-mute);
  font-size: 13.5px;
  line-height: 1.22;
  font-weight: 650;
}
.vb__meta strong { color: var(--fg); display: block; font-weight: 800; font-size: 14.5px; margin-bottom: 2px; }

.vb__more {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 4px 2px;
  margin-top: 6px;
  border-top: 1px dashed var(--line);
  color: var(--fg-mute);
  font-size: 12px;
}

/* ========== LL TBD ========== */

.tbd {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
}
.tbd__drop {
  width: 100%;
  height: 100%;
  border: 2px dashed var(--line-2);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--fg-mute);
  gap: 8px;
  background:
    repeating-linear-gradient(45deg, rgba(255,255,255,0.015) 0 12px, transparent 12px 24px);
  min-height: 220px;
}
.tbd__icon {
  width: 44px; height: 44px;
  display: inline-flex; align-items: center; justify-content: center;
  color: var(--fg-dim);
  border: 2px solid var(--line-2);
  border-radius: 8px;
}
.tbd__title { color: var(--fg-soft); font-size: 16px; font-weight: 600; }
.tbd__sub   { color: var(--fg-mute); font-size: 12.5px; max-width: 360px; }

/* ========== VIDEO (UR) ========== */

.card--video .card__body--video {
  padding: 12px 14px 14px;
}
.video {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
  border-radius: var(--radius-inner);
  overflow: hidden;
  background:
    radial-gradient(120% 80% at 50% 35%, rgba(220, 30, 30, 0.18), transparent 60%),
    radial-gradient(80% 60% at 30% 100%, rgba(0,0,0,0.7), transparent 60%),
    linear-gradient(180deg, #2a0c10 0%, #160a14 60%, #050308 100%);
  border: 1px solid var(--line);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.video__stage {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.video__player {
  position: relative;
  width: 78%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.video__silhouette {
  position: absolute;
  inset: 0;
  display: flex; align-items: center; justify-content: center;
}
.video__silhouette svg { width: 92%; height: 100%; }
.video__crowd {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(60% 40% at 50% 10%, rgba(180, 30, 40, 0.55), transparent 60%),
    radial-gradient(80% 30% at 50% 100%, rgba(0,0,0,0.85), transparent 70%),
    repeating-radial-gradient(circle at 50% 20%, rgba(255,255,255,0.04) 0 2px, transparent 2px 6px);
  pointer-events: none;
  opacity: 0.6;
}
.video__polsat {
  position: absolute;
  top: 12px; left: 12px;
  background: linear-gradient(180deg, #0a2a82, #082366);
  color: #fff;
  font-weight: 800;
  letter-spacing: 1px;
  padding: 4px 8px 4px 8px;
  border-radius: 4px;
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px;
  line-height: 1;
}
.video__polsat::before {
  content: "";
  display: inline-block;
  width: 14px; height: 10px;
  background: #fff;
  -webkit-mask: radial-gradient(circle at 50% 50%, #000 2px, transparent 2.5px);
          mask: radial-gradient(circle at 50% 50%, #000 2px, transparent 2.5px);
  background-color: #ffd400;
  border-radius: 2px;
}
.video__polsat-sport { font-size: 10px; color: #cfe2ff; letter-spacing: 1.5px; display: block; }

.video__live {
  position: absolute;
  top: 12px; right: 12px;
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(255, 80, 80, 0.4);
  color: #ff7d7d;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.6px;
  padding: 4px 8px;
  border-radius: 4px;
}
.video__live::before {
  content: "";
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 6px rgba(255,59,59,0.8);
  animation: pulse 1.4s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.5; transform: scale(0.7); }
}

.video__bar {
  display: grid;
  grid-template-columns: auto 1fr;
  align-items: center;
  gap: 12px;
  padding: 8px 12px;
  background: linear-gradient(180deg, rgba(0,0,0,0.0), rgba(0,0,0,0.7));
  color: #d8e0ec;
  font-size: 12px;
}
.video__bar-live {
  display: inline-flex; align-items: center; gap: 6px;
  color: #ff7d7d;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.6px;
}
.video__bar-live::before {
  content: ""; width: 8px; height: 8px; border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 6px rgba(255,59,59,0.8);
}
.video__bar-progress {
  position: relative;
  height: 4px;
  background: rgba(255,255,255,0.18);
  border-radius: 2px;
  overflow: hidden;
}
.video__bar-progress::before {
  content: "";
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 32%;
  background: linear-gradient(90deg, #ff3b3b, #ff7d7d);
  border-radius: 2px;
}
.video__bar-live.is-muted { color: var(--fg-mute); }
.video__bar-live.is-muted::before { background: var(--fg-dim); box-shadow: none; }
.video__bar-text {
  color: var(--fg-mute);
  font-size: 11px;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.video__stage--polsatgo { padding: 34px 22px 18px; }
.polsatgo-panel {
  position: relative;
  z-index: 1;
  width: min(92%, 520px);
  min-height: 220px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 24px 26px;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(5, 15, 42, 0.78), rgba(5, 7, 14, 0.72));
  border: 1px solid rgba(116, 156, 255, 0.22);
  box-shadow: 0 20px 50px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.04);
  text-align: center;
}
.polsatgo-logo {
  font-weight: 900;
  letter-spacing: 1.4px;
  font-size: 24px;
  color: #fff;
}
.polsatgo-logo span { color: #ffd84d; }
.polsatgo-channel {
  color: #dce8ff;
  font-size: 22px;
  font-weight: 850;
}
.polsatgo-title {
  color: var(--fg-soft);
  font-size: 13.5px;
  font-weight: 650;
}
.polsatgo-status {
  margin-top: 4px;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 850;
  letter-spacing: 0.7px;
  border: 1px solid rgba(255,255,255,0.12);
}
.polsatgo-status.is-live {
  color: #ffb3b3;
  background: rgba(255, 59, 59, 0.12);
  border-color: rgba(255, 59, 59, 0.35);
}
.polsatgo-status.is-ready {
  color: #b8c5d8;
  background: rgba(255,255,255,0.06);
}
.polsatgo-note {
  max-width: 420px;
  color: var(--fg-mute);
  font-size: 11.5px;
  line-height: 1.35;
}

/* ========== SLIDESHOW (LR) ========== */

.card--slideshow .card__body--slideshow {
  padding: 12px 14px 14px;
}
.slideshow {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
  border-radius: var(--radius-inner);
  overflow: hidden;
  background: linear-gradient(180deg, #1b2735 0%, #0a121d 100%);
  border: 1px solid var(--line);
}
.slideshow__photo {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(60% 35% at 25% 90%, rgba(20, 50, 80, 0.85), transparent 70%),
    radial-gradient(80% 30% at 70% 95%, rgba(20, 60, 90, 0.6), transparent 70%),
    linear-gradient(180deg, #1d2c40 0%, #0a1424 100%);
  display: flex; align-items: flex-end; justify-content: center;
}
.slideshow__skyline {
  position: absolute; left: 0; right: 0; top: 18%;
  height: 50%;
  background:
    linear-gradient(180deg, transparent 0%, rgba(245, 200, 150, 0.18) 30%, rgba(120, 80, 50, 0.4) 70%, transparent 100%);
  filter: blur(0.5px);
  clip-path: polygon(
    0% 100%, 0% 60%, 6% 55%, 10% 70%, 14% 50%, 18% 62%, 24% 45%, 30% 60%,
    36% 40%, 44% 55%, 50% 35%, 58% 50%, 64% 30%, 70% 48%, 78% 36%, 86% 52%, 92% 38%, 100% 50%, 100% 100%
  );
}
.slideshow__lake {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 36%;
  background: linear-gradient(180deg, #0a3550 0%, #052a40 100%);
}
.slideshow__lake::after {
  content: "";
  position: absolute; left: 0; right: 0; top: 0; bottom: 0;
  background:
    radial-gradient(80% 40% at 50% 0%, rgba(255, 220, 180, 0.18), transparent 60%),
    repeating-linear-gradient(180deg, rgba(255,255,255,0.04) 0 1px, transparent 1px 4px);
  mix-blend-mode: screen;
  opacity: 0.7;
}
.slideshow__trees {
  position: absolute; left: 0; right: 0; bottom: 22%;
  height: 24%;
  background:
    linear-gradient(180deg, transparent 0%, #0c1e2e 60%, transparent 100%),
    radial-gradient(8% 24% at 6% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 24% at 14% 100%, #08131f 80%, transparent 82%),
    radial-gradient(7% 22% at 22% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 26% at 30% 100%, #08131f 80%, transparent 82%),
    radial-gradient(7% 22% at 38% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 24% at 46% 100%, #08131f 80%, transparent 82%),
    radial-gradient(7% 22% at 54% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 26% at 62% 100%, #08131f 80%, transparent 82%),
    radial-gradient(7% 24% at 70% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 24% at 78% 100%, #08131f 80%, transparent 82%),
    radial-gradient(7% 22% at 86% 100%, #08131f 80%, transparent 82%),
    radial-gradient(8% 24% at 94% 100%, #08131f 80%, transparent 82%);
  opacity: 0.85;
}
.slideshow__photo--image {
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  display: block;
}
.slideshow__photo--image::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(5, 12, 20, 0.04) 0%, rgba(5, 12, 20, 0.18) 70%, rgba(5, 12, 20, 0.42) 100%);
  pointer-events: none;
}
.slideshow__caption {
  position: absolute; left: 14px; bottom: 12px;
  max-width: 70%;
  padding: 7px 10px;
  border-radius: 999px;
  background: rgba(5, 12, 20, 0.52);
  border: 1px solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.88);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  backdrop-filter: blur(10px);
}
.slideshow__counter {
  position: absolute;
  left: 50%; bottom: 12px;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  color: #d8e0ec;
  font-size: 12px;
  letter-spacing: 0.4px;
  padding: 4px 10px;
  border-radius: 12px;
  border: 1px solid var(--line);
  font-variant-numeric: tabular-nums;
}

/* small screen fallback (should not be needed at 1920x1200 but keeps it safe) */
@media (max-width: 1500px) {
  :root { --ticker-h: 48px; }
  .layout { grid-template-columns: 360px 1fr 620px; }
  .weather__temp { font-size: 44px; }
}
