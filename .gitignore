# Pedro Dashboard .gitignore
# Backup / runtime state lives outside repo, but be defensive.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Runtime state (regenerated by scripts/)
app/state/
app/logs/
*.log

# Quarantined / unapproved
_quarantine_unapproved_assets/

# Local backups inside project
backups/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Secrets (defensive — should never live in repo, but never commit if they appear)
.env
.env.*
*.pem
*.key

# Runtime media cache (regenerated; do not backup private photo cache)
app/static/cache/

.test/
